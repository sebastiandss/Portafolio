---
---
<section id="projects">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow" style="color:var(--blue)">
        <div class="eyebrow-dot" style="background:var(--blue)"></div>
        04 · Proyectos
      </div>
      <h2 class="section-title">Lo que construyo<br><em style="font-style:italic;color:var(--blue)">por mi cuenta</em></h2>
    </div>

    <div class="proj-card reveal">
      <div class="proj-top">
        <div class="proj-deco1"></div>
        <div class="proj-deco2"></div>

        <svg width="200" height="120" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <rect x="12" y="6" width="72" height="108" rx="12" fill="#1e1e1e" stroke="#5cb8ff" stroke-width="2.5"/>
          <rect x="20" y="18" width="56" height="84" rx="6" fill="#0a0a0a"/>
          <rect x="26" y="24" width="44" height="7" rx="3" fill="#5cb8ff" opacity=".8"/>
          <rect x="96" y="20" width="92" height="36" rx="10" fill="#252525" stroke="#f9e535" stroke-width="2"/>
          <text x="112" y="48" font-family="Nunito,sans-serif" font-size="14" font-weight="900" fill="#f9e535">$47.900</text>
          <rect x="96" y="66" width="92" height="32" rx="10" fill="#252525" stroke="#3dffc0" stroke-width="2"/>
          <text x="120" y="91" font-family="Nunito,sans-serif" font-size="9" font-weight="800" fill="#3dffc0">Activo</text>
        </svg>

        <div style="flex:1;">
          <div class="proj-tags">
            <span class="etag" style="background:rgba(92,184,255,.12);color:var(--blue);border-color:rgba(92,184,255,.25);">Proyecto personal</span>
            <span class="etag" style="background:rgba(249,229,53,.1);color:var(--yellow);border-color:rgba(249,229,53,.22);">🚀 Astro</span>
          </div>
          <h3 class="proj-name">Gestor de<br>Suscripciones</h3>
          <p class="proj-date">2025 · En desarrollo</p>
        </div>
      </div>

      <div class="proj-body">
        <p class="proj-desc">
          App para gestionar y visualizar tus suscripciones mensuales. <b>El frontend está completo</b> con todas sus funcionalidades. El siguiente paso es construir el backend para soporte de usuarios reales.
        </p>

        <div class="prog-bar-wrap">
          <div class="prog-label">
            <span>Progreso</span>
            <span style="color:var(--blue);">Frontend · 100% ✓</span>
          </div>
          <div class="prog-track"><div class="prog-fill"></div></div>
          <div class="prog-steps">
            <span class="prog-step" style="color:var(--mint);">✓ UI/UX</span>
            <span class="prog-step" style="color:var(--mint);">✓ Lógica</span>
            <span class="prog-step" style="color:rgba(255,255,255,.2);">○ Backend</span>
          </div>
        </div>

        <div class="feat-grid">
          <div class="feat-item"><span style="color:var(--mint);">✓</span> Ver suscripciones</div>
          <div class="feat-item"><span style="color:var(--mint);">✓</span> Total mensual</div>
          <div class="feat-item" style="color:rgba(255,255,255,.2);"><span>○</span> Auth de usuarios</div>
        </div>

        <div class="proj-btns">
          <a href="#" class="btn btn-y small">Ver demo →</a>
          <a href="https://github.com/tu-usuario" class="btn btn-g small" target="_blank">↗ GitHub</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #projects { background: var(--ink); padding: 7rem 3rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .proj-card { max-width: 820px; background: var(--ink2); border: 2.5px solid rgba(255,255,255,.08); border-radius: 24px; overflow: hidden; box-shadow: 6px 6px 0 rgba(0,0,0,.6); }
  .proj-top { background: var(--ink3); border-bottom: 2.5px solid rgba(255,255,255,.06); padding: 2.5rem; display: flex; align-items: center; gap: 2rem; position: relative; overflow: hidden; }
  .proj-deco1 { position: absolute; top: -30px; right: -30px; width: 160px; height: 160px; border-radius: 50%; background: var(--blue); opacity: .06; }
  .proj-tags { display: flex; gap: .7rem; margin-bottom: .8rem; flex-wrap: wrap; }
  .proj-name { font-family: 'Fraunces', serif; font-size: 1.9rem; font-weight: 900; color: var(--white); line-height: 1.1; margin-bottom: .5rem; }
  .proj-date { font-size: .75rem; color: var(--off); font-weight: 600; }
  .proj-body { padding: 2.2rem 2.5rem; }
  .proj-desc { font-size: .9rem; line-height: 1.85; color: var(--off); margin-bottom: 1.8rem; max-width: 580px; }
  .prog-bar-wrap { margin-bottom: 1.8rem; }
  .prog-label { display: flex; justify-content: space-between; font-size: .7rem; font-weight: 800; margin-bottom: .6rem; text-transform: uppercase; }
  .prog-track { height: 8px; background: rgba(255,255,255,.06); border-radius: 100px; position: relative; }
  .prog-fill { height: 100%; width: 60%; background: linear-gradient(90deg, var(--blue), var(--mint)); border-radius: 100px; }
  .prog-steps { display: flex; justify-content: space-between; margin-top: .6rem; font-size: .63rem; font-weight: 700; }
  .feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; margin-bottom: 2rem; font-size: .78rem; font-weight: 700; }
  .proj-btns { display: flex; gap: .8rem; }
  .btn.small { font-size: .75rem; padding: .65rem 1.4rem; }

  @media (max-width: 900px) {
    #projects { padding: 5rem 1.5rem; }
    .proj-top { flex-direction: column; text-align: center; }
  }
</style>