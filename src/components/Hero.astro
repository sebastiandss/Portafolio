</section>

<style>
  #hero {
    position: relative; min-height: 100vh;
    display: grid; grid-template-columns: 1fr 420px;
    align-items: center; padding: 8rem 3rem 4rem; gap: 3rem;
    z-index: 1; overflow: hidden;
  }
  #hero::before {
    content: ''; position: absolute; right: -60px; top: 50%;
    transform: translateY(-50%); width: 520px; height: 520px;
    border-radius: 50%; background: var(--ink2);
    border: 3px solid rgba(249,229,53,.18); z-index: 0;
  }
  .hero-left { position: relative; z-index: 2; }
  .hero-tag {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--ink3); border: 2px solid rgba(255,255,255,.1);
    border-radius: 100px; padding: .35rem 1rem;
    font-size: .72rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase;
    color: var(--mint); margin-bottom: 2rem;
    animation: popIn .5s .1s cubic-bezier(.34,1.56,.64,1) both;
  }
  .hero-tag .dot {
    width: 7px; height: 7px; background: var(--mint); border-radius: 50%;
    animation: blink 1.8s ease-in-out infinite;
  }
  .hero-name {
    font-family: 'Fraunces', serif; font-size: clamp(3.5rem, 8vw, 7.5rem);
    font-weight: 900; line-height: .95; letter-spacing: -.03em; margin-bottom: 1.2rem;
    animation: popIn .6s .2s cubic-bezier(.34,1.56,.64,1) both;
  }
  .hero-name .line2 { font-style: italic; color: var(--yellow); display: block; }
  .hero-name .line1 { display: block; -webkit-text-stroke: 1px rgba(247,247,240,.15); }
  .hero-sub {
    font-size: 1rem; font-weight: 600; color: var(--off); line-height: 1.7;
    max-width: 460px; margin-bottom: 2.5rem;
    animation: popIn .6s .35s cubic-bezier(.34,1.56,.64,1) both;
  }
  .hero-btns {
    display: flex; gap: 1rem; flex-wrap: wrap;
    animation: popIn .6s .45s cubic-bezier(.34,1.56,.64,1) both;
  }
  .hero-illo {
    position: relative; z-index: 2;
    display: flex; align-items: center; justify-content: center;
    animation: floatBob 4s ease-in-out infinite;
  }

  @keyframes blink { 0%, 100% { opacity: 1; transform: scale(1) } 50% { opacity: .3; transform: scale(.6) } }
  @keyframes floatBob { 0%, 100% { transform: translateY(0) } 50% { transform: translateY(-14px) } }
  @keyframes popIn {
    from { opacity: 0; transform: scale(.85) translateY(12px) }
    to { opacity: 1; transform: scale(1) translateY(0) }
  }

  @media (max-width: 900px) {
    #hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 3rem; }
    #hero::before, .hero-illo { display: none; }
  }
</style>