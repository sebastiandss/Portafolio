    <text x="24" y="80" font-size="22" fill="#ff5c5c" opacity=".8">✦</text>
    <text x="316" y="290" font-size="16" fill="#3dffc0" opacity=".7">★</text>
    <text x="60" y="340" font-size="13" fill="#5cb8ff" opacity=".6">◆</text>
    <text x="295" y="60" font-size="11" fill="#c084fc" opacity=".8">●</text>
    <path d="M80 360 Q100 350 120 360 Q140 370 160 360 Q180 350 200 360 Q220 370 240 360 Q260 350 280 360" stroke="#ff5c5c" stroke-width="2.5" fill="none" opacity=".25" stroke-linecap="round"/>

    <rect x="130" y="315" width="100" height="28" rx="8" fill="#1a1a1a" stroke="rgba(255,255,255,.1)" stroke-width="1.5"/>
    <text x="180" y="333" text-anchor="middle" font-family="Nunito,sans-serif" font-size="10" font-weight="800" fill="#a8a89e">@ EBS · 2025–hoy</text>
  </svg>
