      <a href="#contact" class="btn btn-g">Hablemos</a>
    </div>
  </div>

  <div class="hero-illo">
  <svg width="360" height="400" viewBox="0 0 360 400" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="60" y="80" width="240" height="170" rx="16" fill="#1e1e1e" stroke="#ff5c5c" stroke-width="3.5"/>
    <rect x="74" y="94" width="212" height="142" rx="8" fill="#0a0a0a"/>

    <rect x="88" y="112" width="110" height="7" rx="3.5" fill="#ff5c5c" opacity=".9"/> <rect x="88" y="127" width="90" height="7" rx="3.5" fill="#3dffc0" opacity=".8"/> <rect x="182" y="127" width="40" height="7" rx="3.5" fill="#5cb8ff" opacity=".7"/> <rect x="88" y="142" width="130" height="7" rx="3.5" fill="#c084fc" opacity=".8"/> <rect x="88" y="157" width="60" height="7" rx="3.5" fill="#ff5c5c" opacity=".6"/>
    <rect x="152" y="157" width="70" height="7" rx="3.5" fill="#3dffc0" opacity=".5"/>
    <rect x="88" y="172" width="140" height="7" rx="3.5" fill="#f7f7f0" opacity=".7"/>

    <rect x="88" y="187" width="8" height="12" rx="1" fill="#f7f7f0" opacity=".9">
      <animate attributeName="opacity" values="0.9;0;0.9" dur="1.1s" repeatCount="indefinite"/>
    </rect>

    <rect x="155" y="250" width="50" height="30" rx="4" fill="#1e1e1e" stroke="#ff5c5c" stroke-width="3"/>
    <rect x="130" y="278" width="100" height="12" rx="6" fill="#1e1e1e" stroke="#ff5c5c" stroke-width="3"/>

    <g transform="translate(18,130)">
      <rect width="72" height="34" rx="10" fill="#252525" stroke="#ff5c5c" stroke-width="2.5"/>
      <circle cx="16" cy="17" r="7" fill="#ff5c5c" opacity=".3"/>
      <path d="M13 14h6v5a3 3 0 0 1-3 3h0a3 3 0 0 1-3-3v-5zM19 15h1a1.5 1.5 0 0 1 0 3h-1" stroke="#ff5c5c" stroke-width="1.5" stroke-linecap="round"/>
      <text x="31" y="22" font-family="Nunito,sans-serif" font-size="10" font-weight="800" fill="#f7f7f0">Java</text>
    </g>
    
    <g transform="translate(262,108)">
      <rect width="90" height="34" rx="10" fill="#252525" stroke="#3dffc0" stroke-width="2.5"/>
      <path d="M272 125l4-4a2 2 0 0 1 2.8 2.8l-4 4" stroke="#3dffc0" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M270 120a5 5 0 0 1 7 7" stroke="#3dffc0" stroke-width="1.5" stroke-linecap="round"/>
      <text x="12" y="22" font-family="Nunito,sans-serif" font-size="10" font-weight="800" fill="#f7f7f0">Astro</text>
